<Window x:Class="ContactManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ContactManager"
        mc:Ignorable="d"
    
        
        Title="Contact Manager" 
        Height="600" MinHeight="500"
        Width="800" MinWidth="500" 
        WindowStartupLocation="CenterScreen"
        >

    <Window.Resources>
        <local:LockToVisibilityConverter x:Key="LockToVisibilityConverter"/>
        <BitmapImage x:Key="WomanAvatar" UriSource="/woman.jpg"/>
        <BitmapImage x:Key="ManAvatar" UriSource="/man.jpg"/>
        <!--TEMPLATKA DLA KONTAKTÓW-->
        <DataTemplate x:Key="ContactListItemTemplate" DataType="ListBoxItem">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Delete contact" Click="MenuItem_DeleteContact"/>
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <Label Content="{Binding Name}" FontSize="20" Padding="3,0,0,0"/>
                    <Label Content="{Binding Surname}" FontSize="20" Padding="3,0,0,0"/>
                </StackPanel>
                <Border Grid.Column="2" VerticalAlignment="Center" Width="50" Height="50" 
                        BorderBrush="Black" BorderThickness="1" Margin="3">
                    <Image Stretch="Fill">
                        <Image.Style>
                            <Style TargetType="{x:Type Image}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Gender}" Value="Female">
                                        <Setter Property="Source" Value="{StaticResource WomanAvatar}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Gender}" Value="Male">
                                        <Setter Property="Source" Value="{StaticResource ManAvatar}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SelectedContactTemplate" DataType="ListBoxItem">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Delete contact" Click="MenuItem_DeleteContact"/>
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="{Binding Name}" FontSize="20" Padding="3,0,0,0" FontWeight="Bold"/>
                        <Label Content="{Binding Surname}" FontSize="20" Padding="3,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                    <Label Content="{Binding Phone}" FontSize="14" Padding="5,0,0,0"/>
                    <Label Content="{Binding Email}" FontSize="14" Padding="5,0,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" VerticalAlignment="Center" 
                        Width="50" Height="50"
                        BorderBrush="Black" BorderThickness="1"
                        Margin="3">
                    <Image Stretch="Fill">
                        <Image.Style>
                            <Style TargetType="{x:Type Image}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Gender}" Value="Female">
                                        <Setter Property="Source" Value="{StaticResource WomanAvatar}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Gender}" Value="Male">
                                        <Setter Property="Source" Value="{StaticResource ManAvatar}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Border>
                        
                
            </Grid>
        </DataTemplate>
        <!---STYL KONTAKTÓW-->
        <CollectionViewSource Source="{Binding Contacts}" x:Key="ContactsViewSource"/>
                <Style x:Key="ContactListItemStyle" TargetType="ListBoxItem">
                    <Setter Property="ContentTemplate" Value="{StaticResource ContactListItemTemplate}"/>
                    

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    
                    <Style.Triggers>
                        
                        <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                            <Setter Property="Background" Value="#FFAFC5FF"/>
                        </Trigger>

                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#FF75A1FF"/>
                        </Trigger>
                        
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#FFFDCF6C"/>
                            <Setter Property="ContentTemplate" Value="{StaticResource SelectedContactTemplate}"/>
                        </Trigger>
                        
                    </Style.Triggers>
                    
                </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            
            <MenuItem Header="File">
                <MenuItem Header="Import" 
                          Click="MenuItem_Import"
                          ToolTip="Import contacts from an XML file"/>
                <MenuItem Header="Export" 
                          Click="MenuItem_Export"
                          ToolTip="Export contacts from an XML file"/>
                <Separator />
                <MenuItem Header="Exit" Click="MenuItem_Exit"/>
            </MenuItem>

            <MenuItem Header="Contacts">
                <MenuItem Header="Add contact" Click="MenuItem_AddContact"/>
                <MenuItem Header="Clear contacts" Click="MenuItem_ClearContacts"/>
            </MenuItem>

            <MenuItem Header="About" Click="MenuItem_About"/>
        </Menu>

        <TabControl Grid.Row="1">
            <TabItem Header="List">
                <ListBox ItemsSource="{Binding Source={StaticResource ResourceKey=ContactsViewSource}}"
                         HorizontalContentAlignment="Stretch"
                         ItemContainerStyle="{StaticResource ContactListItemStyle}"
                         AlternationCount="2"
                         />
                
            </TabItem>
            <TabItem Header="Grid">
                <DataGrid ItemsSource="{Binding Contacts}"
                          AutoGenerateColumns="True"
                          CanUserAddRows="True"/>
            </TabItem>
            <TabItem Header="Validation Settings">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Width="200" Height="30"
                            Content="Toggle validation settings"
                            Click="ToggleValidationSettings_Click"/>
                    
                    
                    <StackPanel Grid.Row="1" Margin="0,20,0,0"
                                Visibility="{Binding IsValidationUnlocked, Converter={StaticResource LockToVisibilityConverter}}">
                        <TextBlock Text="Assign validation rules to fields:" FontSize="16" FontWeight="Bold"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Content="Name:" Grid.Row="0" Grid.Column="0" Margin="5"/>
                            <ComboBox ItemsSource="{Binding AvailableRules}" 
                                      SelectedItem="{Binding SelectedNameRule}" 
                                      DisplayMemberPath="Name" 
                                      Grid.Row="0" Grid.Column="1" Margin="5"/>     

                            <Label Content="Surname:" Grid.Row="1" Grid.Column="0" Margin="5"/>
                            <ComboBox ItemsSource="{Binding AvailableRules}" 
                                      SelectedItem="{Binding SelectedSurnameRule}" 
                                      DisplayMemberPath="Name" 
                                      Grid.Row="1" Grid.Column="1" Margin="5"/>

                            <Label Content="Email:" Grid.Row="2" Grid.Column="0" Margin="5"/>
                            <ComboBox ItemsSource="{Binding AvailableRules}" 
                                      SelectedItem="{Binding SelectedEmailRule}" 
                                      DisplayMemberPath="Name" 
                                      Grid.Row="2" Grid.Column="1" Margin="5"/>

                            <Label Content="Phone:" Grid.Row="3" Grid.Column="0" Margin="5"/>
                            <ComboBox ItemsSource="{Binding AvailableRules}" 
                                      SelectedItem="{Binding SelectedPhoneRule}" 
                                      DisplayMemberPath="Name" 
                                      Grid.Row="3" Grid.Column="1" Margin="5"/>

                        </Grid>
                    </StackPanel>

                </Grid>
                
            </TabItem>
        </TabControl>
            
    </Grid>
    
    
</Window>
